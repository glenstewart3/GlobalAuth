# MPS Auth — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Database ────────────────────────────────────────────────────────
# PostgreSQL (production — recommended)
DATABASE_URL="postgresql://mpsauth:yourpassword@localhost:5432/mpsauth"

# SQLite fallback (development only — remove for production)
# DATABASE_URL="sqlite+aiosqlite:////var/www/auth/backend/mps_auth.db"

# ── Authentication ───────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="replace-with-64-char-random-hex"

# Set to "true" on HTTPS servers (required for secure cookies)
COOKIE_SECURE="true"

# ── API ──────────────────────────────────────────────────────────────
API_PREFIX="/auth/api"

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="https://apps.mps.edu.vic.gov.au"

# ── Legacy (unused — kept so env loader does not error) ─────────────
MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"
